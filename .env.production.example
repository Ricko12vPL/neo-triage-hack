# Production environment variables — Railway backend
# Copy to .env.production and fill in. NEVER commit .env.production.
# Inject via Railway dashboard → Variables tab (not via files).

# Required
ANTHROPIC_API_KEY=sk-ant-...

# Optional (only if JPL/NASA integration active)
NASA_API_KEY=...

# Runtime
ENVIRONMENT=production
LOG_LEVEL=INFO
CLAUDE_MODEL=claude-opus-4-7

# CORS: comma-separated additional origins beyond localhost + *.vercel.app
# Example: CORS_ORIGINS=https://neo-triage.vercel.app
CORS_ORIGINS=

# Budget guard (USD ceiling before agent pauses)
DAILY_SPEND_CAP_USD=50

# Railway auto-provides PORT — do not set manually
# PORT=8000
